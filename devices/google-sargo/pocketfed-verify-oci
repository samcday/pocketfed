#!/bin/sh
set -eu

rpm -q phosh upower upower-libs
systemctl is-enabled upower.service
rpm -q kernel
rpm -q clatd tayga libqmi-utils
rpm -q --qf '%{VERSION}-%{RELEASE}\n' ModemManager |
    grep -Eq '^1\.24\.2-4\.1\.pocketfed\.fc[0-9]+$'

test -x /usr/lib/NetworkManager/dispatcher.d/50-clatd
grep -Fq 'device-add|device-delete)' /usr/lib/NetworkManager/dispatcher.d/50-clatd
grep -Fq 'qmapmux*|rmnet*)' /usr/lib/NetworkManager/dispatcher.d/50-clatd
grep -Fq 'priority mangle + 1; }' /usr/bin/clatd
systemctl is-enabled clatd.service

test -x /usr/libexec/pocketfed-sargo-uim-select
systemctl is-enabled pocketfed-sargo-uim-select.service
test -L /etc/systemd/system/ModemManager.service.wants/pocketfed-sargo-uim-select.service

systemctl is-enabled systemd-boot-check-no-failures.service
systemctl is-enabled qbootctl.service

/usr/libexec/pocketfed-verify-kernel

set -- /usr/lib/modules/*
[ "$#" -eq 1 ]
test -f "$1/vmlinuz"
test -f "$1/dtb/qcom/sdm670-google-sargo.dtb"
test -f "$1/initramfs.img"
test -f "$1/aboot.img"
