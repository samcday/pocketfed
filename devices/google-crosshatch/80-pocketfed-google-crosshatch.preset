enable clatd.service
enable pocketfed-usb-developer-mode.service
enable systemd-boot-check-no-failures.service
enable systemd-timesyncd.service
enable usb-signaller.service
# The bring-up GLINK quarantine prevents the modem remoteproc and QRTR
# services from ever becoming usable. Keep rmtfs's restart loop and the idle
# TFTP daemon out of this deliberately modem-less Crosshatch boot.
disable rmtfs.service
disable tqftpserv.service
