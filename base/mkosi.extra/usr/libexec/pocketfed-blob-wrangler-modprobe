#!/usr/bin/env bash
set -euo pipefail

declare -A command_line_blacklist=()
for argument in $(</proc/cmdline); do
    case "$argument" in
        module_blacklist=*|modprobe.blacklist=*)
            IFS=, read -r -a modules <<<"${argument#*=}"
            for module in "${modules[@]}"; do
                module=${module//-/_}
                if [[ -n "$module" ]]; then
                    command_line_blacklist["$module"]=1
                fi
            done
            ;;
    esac
done

blacklisted_dependency() {
    local dependencies=$1 action path module

    while read -r action path _; do
        [[ "$action" == insmod ]] || continue
        module=${path##*/}
        module=${module%%.ko*}
        module=${module//-/_}
        if [[ -n "${command_line_blacklist[$module]:-}" ]]; then
            printf '%s\n' "$module"
            return 0
        fi
    done <<<"$dependencies"

    return 1
}

drivers=(
    qcom_q6v5
    qcom_q6v5_pas
    qcom_q6v5_adsp
    qcom_q6v5_mss
    qcom_q6v5_wcss
    qcom_wcnss_pil
    qcom_common
    qcom_sysmon
    qcom_pil_info
    ath10k_snoc
    wcn36xx
    wcnss_ctrl
    btqca
    btqcomsmd
    hci_uart
    ipa
)

available=()
for driver in "${drivers[@]}"; do
    if dependencies=$(modprobe --show-depends "$driver" 2>/dev/null); then
        if dependency=$(blacklisted_dependency "$dependencies"); then
            printf 'pocketfed-blob-wrangler-modprobe: skipping %s: dependency %s is command-line blacklisted\n' \
                "$driver" "$dependency" >&2
        else
            available+=("$driver")
        fi
    else
        printf 'pocketfed-blob-wrangler-modprobe: skipping unavailable module: %s\n' "$driver" >&2
    fi
done

if ((${#available[@]} > 0)); then
    modprobe -a "${available[@]}"
fi

# Firmware-backed platform drivers may be auto-loaded before blob-wrangler has
# populated /usr/lib/firmware. Venus returns a hard probe error in that case,
# so the driver core does not retry it when the firmware appears. Reload the
# otherwise-unused module once after extraction when a Venus device is still
# unbound.
venus_unbound=0
for device in /sys/bus/platform/devices/*; do
    [[ -f "$device/modalias" && ! -e "$device/driver" ]] || continue
    case "$(<"$device/modalias")" in
        *Cqcom,*venus*) venus_unbound=1 ;;
    esac
done

if ((venus_unbound)); then
    if dependencies=$(modprobe --show-depends venus_core 2>/dev/null) &&
        dependency=$(blacklisted_dependency "$dependencies")
    then
        printf 'pocketfed-blob-wrangler-modprobe: skipping Venus reload: dependency %s is command-line blacklisted\n' \
            "$dependency" >&2
    else
        venus_refcount=$(awk '$1 == "venus_core" { print $3 }' /proc/modules)
        if [[ -n "$venus_refcount" && "$venus_refcount" != 0 ]]; then
            printf 'pocketfed-blob-wrangler-modprobe: Venus remains unbound but venus_core is in use; skipping reload\n' >&2
        else
            if [[ -n "$venus_refcount" ]]; then
                modprobe -r venus_core
            fi
            modprobe venus_core
        fi
    fi
fi
