#!/usr/bin/env bash
set -euo pipefail

cfg_BOOT_TYPE=aboot-gptctl
cfg_PARTITION_A=/dev/disk/by-partlabel/boot_a
cfg_PARTITION_B=/dev/disk/by-partlabel/boot_b
cfg_PAGESIZE=4096
cfg_BASE=0x0
cfg_KERNEL_OFFSET=0x00008000
cfg_RAMDISK_OFFSET=0x01000000
cfg_SECOND_OFFSET=0x00f00000
cfg_TAGS_OFFSET=0x00000100
cfg_DTB_OFFSET=0x01f00000
cfg_DTB_FILE=auto
cfg_CMDLINE=

rootdir=/
config_path=/boot/aboot.cfg
local_mode=0
options=
verbose=0

usage() {
    cat >&2 <<'EOF'
Usage: aboot-deploy [OPTIONS] aboot_img
Options:
  -h, --help                       Show this help message
  -c, --config PATH                Config file to read
  -l, --local                      Local kernel-install mode, not implemented yet
  -o, --options CMDLINE            Kernel command line of the next OSTree boot
  -r, --root PATH                  Target sysroot
  -v, --verbose                    Show verbose output

Environment:
  POCKETFED_ABOOT_COMPATIBLE       Override DT compatible, e.g. oneplus,fajita
  POCKETFED_ABOOT_CMDLINE          Override command line written to boot.img
  POCKETFED_ABOOT_DTB              Override DTB path
  POCKETFED_DROID_EXORCIST=1       Prepare kernel with droid-exorcist
  POCKETFED_DROID_EXORCIST_ASSEMBLER
                                    droid-exorcist-assembler host binary
  POCKETFED_DROID_EXORCIST_SHIM    Raw droid-exorcist arm64 Image
  POCKETFED_ABOOT_NO_FLASH=1       Generate the image but do not write partitions
  POCKETFED_ABOOT_OUTPUT=PATH      Image output path for no-flash/dev flows
  POCKETFED_ABOOT_FLASH=1          Allow writing boot partitions
EOF
}

die() {
    printf 'aboot-deploy: %s\n' "$*" >&2
    exit 1
}

log() {
    printf 'aboot-deploy: %s\n' "$*" >&2
}

vlog() {
    if (( verbose )); then
        log "$@"
    fi
}

trim() {
    local value=$1
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

strip_quotes() {
    local value=$1
    if (( ${#value} >= 2 )); then
        local first=${value:0:1}
        local last=${value: -1}
        if [[ "$first" == "$last" && ( "$first" == "'" || "$first" == '"' ) ]]; then
            value=${value:1:${#value}-2}
        fi
    fi
    printf '%s' "$value"
}

set_config_value() {
    local key=$1
    local value=$2

    case "$key" in
        BOOT_TYPE) cfg_BOOT_TYPE=$value ;;
        PARTITION_A) cfg_PARTITION_A=$value ;;
        PARTITION_B) cfg_PARTITION_B=$value ;;
        PAGESIZE) cfg_PAGESIZE=$value ;;
        BASE) cfg_BASE=$value ;;
        KERNEL_OFFSET) cfg_KERNEL_OFFSET=$value ;;
        RAMDISK_OFFSET) cfg_RAMDISK_OFFSET=$value ;;
        SECOND_OFFSET) cfg_SECOND_OFFSET=$value ;;
        TAGS_OFFSET) cfg_TAGS_OFFSET=$value ;;
        DTB_OFFSET) cfg_DTB_OFFSET=$value ;;
        DTB_FILE) cfg_DTB_FILE=$value ;;
        CMDLINE) cfg_CMDLINE=$value ;;
        COMPRESS_KERNEL) ;;
        VBMETA_PARTITION_A | VBMETA_PARTITION_B | PARTITION_CTL) ;;
        *) die "unknown config key in $config_path: $key" ;;
    esac
}

load_config() {
    local path=$1
    local line key value

    [[ -f "$path" ]] || die "missing aboot config: $path"

    while IFS= read -r line || [[ -n "$line" ]]; do
        line=$(trim "$line")
        [[ -z "$line" || "${line:0:1}" == '#' ]] && continue
        [[ "$line" == *=* ]] || continue

        key=$(trim "${line%%=*}")
        value=$(trim "${line#*=}")
        value=$(strip_quotes "$value")
        set_config_value "$key" "$value"
    done <"$path"
}

join_root() {
    local path=$1

    if [[ "$rootdir" == / ]]; then
        printf '/%s' "${path#/}"
    elif [[ "$path" == /* ]]; then
        printf '%s/%s' "$rootdir" "${path#/}"
    else
        printf '%s/%s' "$rootdir" "$path"
    fi
}

cmdline_key() {
    local cmdline=$1
    local key=$2
    local token

    for token in $cmdline; do
        if [[ "$token" == "$key="* ]]; then
            printf '%s' "${token#"$key="}"
            return 0
        fi
    done

    return 1
}

deploy_path=
deploy_rel=

resolve_ostree_deploy_dir() {
    local cmdline=$1
    local ostree_target ostree_link ostree_root resolved

    ostree_target=$(cmdline_key "$cmdline" ostree) \
        || die 'missing ostree= in kernel options passed by OSTree'
    [[ "$ostree_target" == /ostree/* ]] \
        || die "unsupported ostree target outside /ostree: $ostree_target"

    ostree_link=$(join_root "$ostree_target")
    [[ -L "$ostree_link" ]] \
        || die "OSTree target is not a symlink in sysroot: $ostree_target"

    resolved=$(realpath "$ostree_link")
    ostree_root=$(join_root /ostree)
    case "$resolved" in
        "$ostree_root"/*) ;;
        *) die "resolved OSTree target escapes /ostree: $resolved" ;;
    esac

    deploy_path=$resolved
    deploy_rel=${resolved#"$ostree_root"/}
    vlog "resolved OSTree deployment: /ostree/$deploy_rel"
}

root_link_path() {
    local slot=$1
    join_root "/ostree/root.$slot"
}

has_root_links() {
    local root_a root_b
    root_a=$(root_link_path a)
    root_b=$(root_link_path b)
    [[ -e "$root_a" || -L "$root_a" || -e "$root_b" || -L "$root_b" ]]
}

create_root_link() {
    local slot=$1
    local target=$2
    local link tmp

    link=$(root_link_path "$slot")
    mkdir -p "$(dirname "$link")"
    tmp="$link.tmp.$$"
    rm -f "$tmp"
    ln -s "$target" "$tmp"
    mv -Tf "$tmp" "$link"
    vlog "created $link -> $target"
}

aboot_path_from_arg() {
    local arg=$1
    if [[ "$arg" == /* ]]; then
        printf '%s/boot/%s' "$rootdir" "${arg#/}"
    else
        printf '%s/boot/%s' "$rootdir" "$arg"
    fi
}

extract_kernel_version() {
    local image=$1
    local name=${image##*/}
    name=${name%.img}

    [[ "$name" == aboot-* ]] \
        || die "cannot infer kernel version from aboot image name: $image"
    printf '%s' "${name#aboot-}"
}

first_existing_file() {
    local path
    for path in "$@"; do
        if [[ -f "$path" ]]; then
            printf '%s' "$path"
            return 0
        fi
    done
    return 1
}

bool_enabled() {
    case "${1:-}" in
        1 | yes | true | on) return 0 ;;
        *) return 1 ;;
    esac
}

first_existing_executable() {
    local path
    for path in "$@"; do
        if [[ -x "$path" ]]; then
            printf '%s' "$path"
            return 0
        fi
    done
    return 1
}

find_droid_exorcist_assembler() {
    local override=${POCKETFED_DROID_EXORCIST_ASSEMBLER:-}
    local found=

    if [[ -n "$override" ]]; then
        [[ -x "$override" ]] || die "POCKETFED_DROID_EXORCIST_ASSEMBLER is not executable: $override"
        printf '%s' "$override"
        return 0
    fi

    if found=$(command -v droid-exorcist-assembler 2>/dev/null); then
        printf '%s' "$found"
        return 0
    fi

    first_existing_executable \
        "$PWD/../droid-exorcist/target/release/droid-exorcist-assembler" \
        "$PWD/../droid-exorcist/target/debug/droid-exorcist-assembler" \
        /var/home/sam/src/droid-exorcist/target/release/droid-exorcist-assembler \
        /var/home/sam/src/droid-exorcist/target/debug/droid-exorcist-assembler
}

find_droid_exorcist_shim() {
    local override=${POCKETFED_DROID_EXORCIST_SHIM:-}

    if [[ -n "$override" ]]; then
        [[ -f "$override" ]] || die "POCKETFED_DROID_EXORCIST_SHIM does not exist: $override"
        printf '%s' "$override"
        return 0
    fi

    first_existing_file \
        "$PWD/../droid-exorcist/droid-exorcist.bin" \
        /var/home/sam/src/droid-exorcist/droid-exorcist.bin \
        /usr/lib/droid-exorcist/droid-exorcist.bin
}

mark_droid_exorcist_cmdline() {
    local cmdline=$1

    case "$cmdline" in
        *'<S>'*'<E>'*) printf '%s' "$cmdline" ;;
        *'<S>'* | *'<E>'*) die 'droid-exorcist cmdline has only one marker' ;;
        *) printf '<S> %s <E>' "$cmdline" ;;
    esac
}

prepare_droid_exorcist_kernel() {
    local kernel=$1
    local output=$2
    local assembler shim prepared

    assembler=$(find_droid_exorcist_assembler) \
        || die 'droid-exorcist is enabled but droid-exorcist-assembler was not found'
    shim=$(find_droid_exorcist_shim) \
        || die 'droid-exorcist is enabled but droid-exorcist.bin was not found'

    prepared="$output.droid-exorcist-kernel.tmp.$$"
    rm -f "$prepared"
    vlog "preparing kernel with droid-exorcist: $prepared"
    "$assembler" "$kernel" "$shim" >"$prepared"
    chmod 0644 "$prepared"
    printf '%s' "$prepared"
}

detect_compatible() {
    local dt_compatible=/sys/firmware/devicetree/base/compatible
    local compatible

    if [[ -n "${POCKETFED_ABOOT_COMPATIBLE:-}" ]]; then
        printf '%s\n' "$POCKETFED_ABOOT_COMPATIBLE"
        return 0
    fi

    [[ -r "$dt_compatible" ]] || return 1
    while IFS= read -r compatible; do
        [[ -n "$compatible" ]] || continue
        printf '%s\n' "$compatible"
        return 0
    done < <(tr '\0' '\n' <"$dt_compatible")

    return 1
}

dtb_for_compatible() {
    local compatible=$1

    case "$compatible" in
        oneplus,fajita) printf '%s\n' qcom/sdm845-oneplus-fajita.dtb ;;
        oneplus,enchilada) printf '%s\n' qcom/sdm845-oneplus-enchilada.dtb ;;
        *) return 1 ;;
    esac
}

select_dtb() {
    local module_dir=$1
    local override path compatible dtb_rel

    override=${POCKETFED_ABOOT_DTB:-}
    if [[ -n "$override" ]]; then
        if [[ -f "$override" ]]; then
            printf '%s' "$override"
            return 0
        fi
        path=$(join_root "$override")
        [[ -f "$path" ]] || die "POCKETFED_ABOOT_DTB does not exist: $override"
        printf '%s' "$path"
        return 0
    fi

    if [[ -n "$cfg_DTB_FILE" && "$cfg_DTB_FILE" != auto ]]; then
        if [[ "$cfg_DTB_FILE" == /* ]]; then
            path=$(join_root "$cfg_DTB_FILE")
        else
            path="$module_dir/dtb/$cfg_DTB_FILE"
        fi
        [[ -f "$path" ]] || die "configured DTB does not exist: $path"
        printf '%s' "$path"
        return 0
    fi

    compatible=$(detect_compatible) \
        || die 'cannot detect device compatible; set POCKETFED_ABOOT_COMPATIBLE=oneplus,fajita'
    dtb_rel=$(dtb_for_compatible "$compatible") \
        || die "no PocketFed DTB mapping for compatible: $compatible"
    path="$module_dir/dtb/$dtb_rel"
    [[ -f "$path" ]] || die "mapped DTB does not exist: $path"

    vlog "selected DTB for $compatible: $dtb_rel"
    printf '%s' "$path"
}

build_boot_image() {
    local aboot_path=$1
    local kver=$2
    local module_dir=$3
    local aboot_dir kernel kernel_payload prepared_kernel initrd dtb cmdline output tmp

    command -v mkbootimg >/dev/null 2>&1 || die 'mkbootimg not found; install android-tools'

    aboot_dir=$(dirname "$aboot_path")
    kernel=$(first_existing_file \
        "$module_dir/vmlinuz" \
        "$aboot_dir/vmlinuz-$kver" \
        "$aboot_dir/vmlinuz") \
        || die "cannot find kernel for $kver"
    initrd=$(first_existing_file \
        "$aboot_dir/initramfs-$kver.img" \
        "$module_dir/initramfs.img" \
        "$aboot_dir/initrd-$kver.img" \
        "$aboot_dir/initrd.img") \
        || die "cannot find initramfs for $kver"
    dtb=$(select_dtb "$module_dir")

    if [[ -n "${POCKETFED_ABOOT_CMDLINE:-}" ]]; then
        cmdline=$POCKETFED_ABOOT_CMDLINE
    elif [[ -n "$options" ]]; then
        cmdline=$options
    elif [[ -n "$cfg_CMDLINE" ]]; then
        cmdline=$cfg_CMDLINE
    else
        die 'no kernel command line available'
    fi

    output=${POCKETFED_ABOOT_OUTPUT:-$aboot_path}
    mkdir -p "$(dirname "$output")"
    tmp="$output.tmp.$$"
    rm -f "$tmp"

    kernel_payload=$kernel
    prepared_kernel=
    if bool_enabled "${POCKETFED_DROID_EXORCIST:-}"; then
        prepared_kernel=$(prepare_droid_exorcist_kernel "$kernel" "$output")
        kernel_payload=$prepared_kernel
        cmdline=$(mark_droid_exorcist_cmdline "$cmdline")
    fi

    vlog "building Android boot image: $output"
    mkbootimg \
        --base "$cfg_BASE" \
        --kernel_offset "$cfg_KERNEL_OFFSET" \
        --ramdisk_offset "$cfg_RAMDISK_OFFSET" \
        --tags_offset "$cfg_TAGS_OFFSET" \
        --pagesize "$cfg_PAGESIZE" \
        --second_offset "$cfg_SECOND_OFFSET" \
        --ramdisk "$initrd" \
        --dtb_offset "$cfg_DTB_OFFSET" \
        --dtb "$dtb" \
        --kernel "$kernel_payload" \
        --cmdline "$cmdline" \
        --header_version 2 \
        -o "$tmp"
    chmod 0644 "$tmp"
    mv -f "$tmp" "$output"
    rm -f "$prepared_kernel"

    printf '%s' "$output"
}

flash_boot_image() {
    local image=$1
    local cmdline suffix current_slot target_slot target_number partition
    local image_size partition_size

    [[ "${POCKETFED_ABOOT_FLASH:-}" == 1 ]] \
        || die "generated $image; flashing is disabled until POCKETFED_ABOOT_FLASH=1 is set"

    [[ -r /proc/cmdline ]] || die 'cannot determine booted Android slot without /proc/cmdline'
    cmdline=$(</proc/cmdline)
    suffix=$(cmdline_key "$cmdline" androidboot.slot_suffix) \
        || die 'cannot determine booted Android slot without androidboot.slot_suffix='

    case "$suffix" in
        _a) current_slot=a; target_slot=b; target_number=1; partition=$cfg_PARTITION_B ;;
        _b) current_slot=b; target_slot=a; target_number=0; partition=$cfg_PARTITION_A ;;
        *) die "invalid androidboot.slot_suffix: $suffix" ;;
    esac

    [[ -b "$partition" ]] || die "target boot partition is not a block device: $partition"
    image_size=$(stat -c %s "$image")
    partition_size=$(blockdev --getsize64 "$partition")
    (( image_size <= partition_size )) \
        || die "boot image is too large for $partition: $image_size > $partition_size"

    if [[ "$cfg_BOOT_TYPE" == aboot-gptctl ]]; then
        command -v aboot-gptctl >/dev/null 2>&1 || die 'aboot-gptctl is required for flashing'
        aboot-gptctl prepare-switch "$target_number"
    fi

    log "writing $image to inactive slot $target_slot ($partition); booted slot is $current_slot"
    dd if="$image" of="$partition" bs=4M conv=fsync status=none
    create_root_link "$target_slot" "$deploy_rel"

    if [[ "$cfg_BOOT_TYPE" == aboot-gptctl ]]; then
        aboot-gptctl finalize-switch "$target_number"
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h | --help)
            usage
            exit 0
            ;;
        -c | --config)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            config_path=$2
            shift 2
            ;;
        -l | --local)
            local_mode=1
            shift
            ;;
        -o | --options)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            options=$2
            shift 2
            ;;
        -r | --root)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            rootdir=$2
            shift 2
            ;;
        -v | --verbose)
            verbose=1
            shift
            ;;
        --)
            shift
            break
            ;;
        -* )
            die "unknown option: $1"
            ;;
        *)
            break
            ;;
    esac
done

[[ $# -eq 1 ]] || die 'exactly one aboot image argument is required'

rootdir=$(realpath -m "$rootdir")
config_path=$(join_root "$config_path")
load_config "$config_path"

if (( local_mode )); then
    die '--local kernel-install mode is not implemented in PocketFed aboot-deploy yet'
fi

resolve_ostree_deploy_dir "$options"

if ! has_root_links; then
    create_root_link a "$deploy_rel"
    create_root_link b "$deploy_rel"
    log 'initialized /ostree/root.a and /ostree/root.b; not flashing during first install'
    exit 0
fi

aboot_arg=$1
aboot_path=$(aboot_path_from_arg "$aboot_arg")
kver=$(extract_kernel_version "$aboot_arg")
module_dir="$deploy_path/usr/lib/modules/$kver"
[[ -d "$module_dir" ]] || die "missing module directory: $module_dir"

boot_image=$(build_boot_image "$aboot_path" "$kver" "$module_dir")
log "generated $boot_image"

if [[ "${POCKETFED_ABOOT_NO_FLASH:-}" == 1 ]]; then
    printf '%s\n' "$boot_image"
    exit 0
fi

flash_boot_image "$boot_image"
