#!/usr/bin/env bash
set -euxo pipefail

root="${BUILDROOT:?}"

# Mark /etc as initialized; /var is intentionally tmpfiles-owned state.
echo "TIMESTAMP_NSEC=$SOURCE_DATE_EPOCH" > "$root/etc/.updated"

# Keep generated boot/API state out of the rootfs image.
find "$root/boot" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
find "$root/run" -mindepth 1 -maxdepth 1 -exec rm -rf -- {} +
