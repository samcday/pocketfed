#!/usr/bin/env bash
set -euo pipefail

image=
source_imgref=
target_imgref=
output_dir=
size=8G
root_label=pfroot
stateroot=pocketfed
source_ref=install
arch=arm64
deploy_arch=
force=0

usage() {
    cat >&2 <<'EOF'
Usage: bootc-to-fastboot --image IMAGE --output-dir DIR [OPTIONS]

Create fastbootable Android userdata + boot artifacts from a device-bound
bootc/OSTree image that already contains /usr/lib/modules/$kver/aboot.img.

Options:
  --image IMAGE             Local image tag; shorthand for containers-storage:IMAGE
  --source-imgref IMGREF    Full skopeo source imgref; overrides --image shorthand
  --target-imgref IMGREF    Future update origin written into the deployment
  --output-dir DIR          Directory for userdata.raw.img, userdata.img, boot.img
  --size SIZE               Raw userdata image size passed to truncate (default: 8G)
  --root-label LABEL        Ext4 label and root=LABEL= karg (default: pfroot)
  --stateroot NAME          OSTree stateroot/osname (default: pocketfed)
  --source-ref REF          Temporary OCI tag (default: install)
  --arch ARCH               Source image architecture for skopeo selection (default: arm64)
  --deploy-arch ARCH        Temporary OCI metadata arch for host ostree import
  --force                   Replace existing output artifacts
  -h, --help                Show this help

Examples:
  scripts/bootc-to-fastboot \
    --image localhost/pocketfed-google-sargo:umoci-test \
    --target-imgref ghcr.io/samcday/pocketfed-google-sargo:rawhide \
    --output-dir out/google-sargo

  scripts/bootc-to-fastboot \
    --source-imgref docker://ghcr.io/samcday/pocketfed-google-sargo:rawhide \
    --output-dir out/google-sargo
EOF
}

die() {
    printf 'bootc-to-fastboot: %s\n' "$*" >&2
    exit 1
}

log() {
    printf 'bootc-to-fastboot: %s\n' "$*" >&2
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

host_oci_arch() {
    case "$(uname -m)" in
        x86_64) printf 'amd64' ;;
        aarch64) printf 'arm64' ;;
        armv7l) printf 'arm' ;;
        *) uname -m ;;
    esac
}

normalize_source_imgref() {
    local ref=$1
    case "$ref" in
        containers-storage:* | docker://* | oci:* | oci-archive:* | docker-archive:* | dir:*)
            printf '%s' "$ref"
            ;;
        *)
            printf 'containers-storage:%s' "$ref"
            ;;
    esac
}

normalize_target_imgref() {
    local ref=$1
    [[ -n "$ref" ]] || return 0

    case "$ref" in
        ostree-image-signed:* | ostree-unverified-image:* | ostree-unverified-registry:* | ostree-remote-image:* | ostree-remote-registry:*)
            printf '%s' "$ref"
            ;;
        registry:* | docker://* | oci:* | oci-archive:* | containers-storage:* | docker-archive:* | dir:*)
            printf 'ostree-unverified-image:%s' "$ref"
            ;;
        *)
            printf 'ostree-unverified-registry:%s' "$ref"
            ;;
    esac
}

json_escape() {
    local value=$1
    value=${value//\\/\\\\}
    value=${value//"/\\"}
    value=${value//$'\n'/\\n}
    printf '%s' "$value"
}

json_string_or_null() {
    local value=$1
    if [[ -n "$value" ]]; then
        printf '"%s"' "$(json_escape "$value")"
    else
        printf 'null'
    fi
}

oci_blob_path() {
    local oci_dir=$1 digest=$2
    local algo=${digest%%:*}
    local hash=${digest#*:}

    [[ "$algo" == sha256 ]] || die "unsupported OCI digest algorithm: $digest"
    printf '%s/blobs/sha256/%s' "$oci_dir" "$hash"
}

sha256_file() {
    local hash ignored
    read -r hash ignored < <(sha256sum "$1")
    printf '%s' "$hash"
}

rewrite_oci_platform() {
    local oci_dir=$1 ref=$2 platform_arch=$3 platform_os=linux
    local index manifest_digest manifest_file config_digest config_file
    local tmp new_config_hash new_config_size new_manifest_hash new_manifest_size

    index="$oci_dir/index.json"
    manifest_digest=$(jq -r --arg ref "$ref" '
        .manifests as $manifests
        | ($manifests | map(select(.annotations["org.opencontainers.image.ref.name"] == $ref))) as $matches
        | if ($matches | length) == 1 then $matches[0].digest
          elif ($manifests | length) == 1 then $manifests[0].digest
          else empty end
    ' "$index")
    [[ -n "$manifest_digest" ]] || die "cannot identify OCI manifest for ref: $ref"

    manifest_file=$(oci_blob_path "$oci_dir" "$manifest_digest")
    config_digest=$(jq -r '.config.digest' "$manifest_file")
    config_file=$(oci_blob_path "$oci_dir" "$config_digest")

    tmp=$(mktemp "$oci_dir/.config.XXXXXX")
    jq --arg arch "$platform_arch" --arg os "$platform_os" \
        '.architecture = $arch | .os = $os' \
        "$config_file" >"$tmp"
    new_config_hash=$(sha256_file "$tmp")
    new_config_size=$(stat -c %s "$tmp")
    mv -f "$tmp" "$oci_dir/blobs/sha256/$new_config_hash"

    tmp=$(mktemp "$oci_dir/.manifest.XXXXXX")
    jq --arg digest "sha256:$new_config_hash" --argjson size "$new_config_size" \
        '.config.digest = $digest | .config.size = $size' \
        "$manifest_file" >"$tmp"
    new_manifest_hash=$(sha256_file "$tmp")
    new_manifest_size=$(stat -c %s "$tmp")
    mv -f "$tmp" "$oci_dir/blobs/sha256/$new_manifest_hash"

    tmp=$(mktemp "$oci_dir/.index.XXXXXX")
    jq \
        --arg old_digest "$manifest_digest" \
        --arg new_digest "sha256:$new_manifest_hash" \
        --arg arch "$platform_arch" \
        --arg os "$platform_os" \
        --argjson size "$new_manifest_size" \
        '(.manifests[] | select(.digest == $old_digest)) |=
            (.digest = $new_digest | .size = $size | .platform.os = $os | .platform.architecture = $arch)' \
        "$index" >"$tmp"
    mv -f "$tmp" "$index"
}

run_root() {
    "${sudo_cmd[@]}" "$@"
}

set_root_link() {
    local slot=$1
    local link tmp_link

    link="$mnt/ostree/root.$slot"
    tmp_link="$link.tmp.$$"
    run_root rm -f "$tmp_link"
    run_root ln -s "$deployment_rel" "$tmp_link"
    run_root mv -Tf "$tmp_link" "$link"
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --image)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            image=$2
            shift 2
            ;;
        --source-imgref)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            source_imgref=$2
            shift 2
            ;;
        --target-imgref)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            target_imgref=$2
            shift 2
            ;;
        --output-dir)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            output_dir=$2
            shift 2
            ;;
        --size)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            size=$2
            shift 2
            ;;
        --root-label)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            root_label=$2
            shift 2
            ;;
        --stateroot)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            stateroot=$2
            shift 2
            ;;
        --source-ref)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            source_ref=$2
            shift 2
            ;;
        --arch)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            arch=$2
            shift 2
            ;;
        --deploy-arch)
            [[ $# -ge 2 ]] || die "$1 requires an argument"
            deploy_arch=$2
            shift 2
            ;;
        --force)
            force=1
            shift
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            die "unknown option: $1"
            ;;
    esac
done

[[ -n "$output_dir" ]] || die '--output-dir is required'
if [[ -z "$source_imgref" ]]; then
    [[ -n "$image" ]] || die '--image or --source-imgref is required'
    source_imgref=$(normalize_source_imgref "$image")
fi
target_imgref=$(normalize_target_imgref "$target_imgref")
if [[ -z "$deploy_arch" ]]; then
    deploy_arch=$(host_oci_arch)
fi

require_cmd skopeo
require_cmd ostree
require_cmd jq
require_cmd sha256sum
require_cmd truncate
require_cmd mkfs.ext4
require_cmd mount
require_cmd umount
require_cmd e2fsck
require_cmd img2simg
require_cmd realpath

sudo_cmd=()
if (( EUID != 0 )); then
    sudo_bin=${PF_SUDO:-sudo}
    require_cmd "$sudo_bin"
    sudo_cmd=("$sudo_bin")
fi

run_root true

output_dir=$(realpath -m "$output_dir")
mkdir -p "$output_dir"

raw_img="$output_dir/userdata.raw.img"
sparse_img="$output_dir/userdata.img"
boot_img="$output_dir/boot.img"
metadata="$output_dir/metadata.json"
flash_script="$output_dir/flash.sh"

if (( ! force )); then
    for path in "$raw_img" "$sparse_img" "$boot_img" "$metadata" "$flash_script"; do
        [[ ! -e "$path" ]] || die "output exists; use --force: $path"
    done
fi

rm -f "$raw_img" "$sparse_img" "$boot_img" "$metadata" "$flash_script"

tmp=$(mktemp -d)
mnt="$tmp/mnt"
source_oci="$tmp/source.oci"
commit_file="$tmp/commit"
mounted=0

cleanup() {
    set +e
    if (( mounted )) && mountpoint -q "$mnt"; then
        run_root umount "$mnt"
    fi
    rm -rf "$tmp"
}
trap cleanup EXIT

install -d "$mnt"

log "copying source image to temporary OCI layout"
skopeo copy \
    --override-os linux \
    --override-arch "$arch" \
    "$source_imgref" \
    "oci:$source_oci:$source_ref"

# ostree-ext currently validates the image config architecture against the host
# process architecture, even for this offline sysroot import. This temporary OCI
# copy is only an installer source, so rewrite metadata to satisfy that guard;
# the actual arm64 rootfs content is unchanged.
rewrite_oci_platform "$source_oci" "$source_ref" "$deploy_arch"

log "creating ext4 userdata image: $raw_img"
truncate -s "$size" "$raw_img"
mkfs.ext4 -F -L "$root_label" "$raw_img" >/dev/null

log "mounting userdata image"
run_root mount -o loop "$raw_img" "$mnt"
mounted=1

log "initializing OSTree sysroot"
run_root ostree admin init-fs --modern "$mnt"
run_root ostree config --repo "$mnt/ostree/repo" set sysroot.bootloader none
run_root ostree config --repo "$mnt/ostree/repo" set sysroot.bootprefix true
run_root ostree config --repo "$mnt/ostree/repo" set sysroot.readonly true
run_root ostree admin --sysroot="$mnt" stateroot-init "$stateroot"

deploy_args=(
    ostree container image deploy
    --sysroot "$mnt"
    --stateroot "$stateroot"
    --imgref "ostree-unverified-image:oci:$source_oci:$source_ref"
    --write-commitid-to "$commit_file"
    --karg "root=LABEL=$root_label"
    --karg rw
    --karg rootwait
    --karg rootfstype=ext4
)
if [[ -n "$target_imgref" ]]; then
    deploy_args+=(--target-imgref "$target_imgref")
fi

log "deploying image into userdata"
run_root "${deploy_args[@]}"

commit_id=$(<"$commit_file")
deploy_base="$mnt/ostree/deploy/$stateroot/deploy"
shopt -s nullglob
deployments=("$deploy_base"/*.0)
shopt -u nullglob
(( ${#deployments[@]} == 1 )) || die "expected one deployment under $deploy_base, found ${#deployments[@]}"
deployment=${deployments[0]}
deployment_rel=${deployment#"$mnt/ostree/"}
[[ "$deployment_rel" != "$deployment" ]] || die "deployment path is outside /ostree: $deployment"

log "creating initial Android slot root links"
set_root_link a
set_root_link b

shopt -s nullglob
aboots=("$deployment/usr/lib/modules"/*/aboot.img)
shopt -u nullglob
(( ${#aboots[@]} == 1 )) || die "expected one aboot.img in deployment, found ${#aboots[@]}"
aboot=${aboots[0]}

log "copying prebuilt boot image"
run_root install -m0644 "$aboot" "$boot_img"
run_root chown "$(id -u):$(id -g)" "$boot_img"

log "enabling aboot bootloader for future deployments"
run_root ostree config --repo "$mnt/ostree/repo" set sysroot.bootloader aboot

log "unmounting userdata image"
run_root sync
run_root umount "$mnt"
mounted=0

log "checking ext4 image"
set +e
e2fsck -fy "$raw_img"
e2fsck_rc=$?
set -e
(( e2fsck_rc == 0 || e2fsck_rc == 1 )) || die "e2fsck failed with exit code $e2fsck_rc"

log "creating sparse userdata image"
img2simg "$raw_img" "$sparse_img"

cat >"$metadata" <<EOF
{
  "source_imgref": "$(json_escape "$source_imgref")",
  "target_imgref": $(json_string_or_null "$target_imgref"),
  "stateroot": "$(json_escape "$stateroot")",
  "root_label": "$(json_escape "$root_label")",
  "commit": "$(json_escape "$commit_id")",
  "deployment": "$(json_escape "$deployment_rel")",
  "userdata_raw": "userdata.raw.img",
  "userdata_sparse": "userdata.img",
  "boot": "boot.img",
  "userdata_raw_size": $(stat -c %s "$raw_img"),
  "userdata_sparse_size": $(stat -c %s "$sparse_img"),
  "boot_size": $(stat -c %s "$boot_img")
}
EOF

cat >"$flash_script" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
fastboot flash userdata "$dir/userdata.img"
fastboot flash boot_a "$dir/boot.img"
fastboot flash boot_b "$dir/boot.img"
fastboot set_active a
EOF
chmod 0755 "$flash_script"

log "wrote artifacts to $output_dir"
printf '%s\n' "$output_dir"
