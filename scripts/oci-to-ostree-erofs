#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: oci-to-ostree-erofs --imgref IMGREF --output PATH [OPTIONS]

Deploy a bootc/OSTree container image into an OSTree sysroot and pack it as EROFS.

Options:
  --imgref IMGREF             Source image reference. Supports skopeo transports such as
                              oci:/path/to/layout:tag, containers-storage:NAME:TAG,
                              docker://REGISTRY/NAME:TAG, and oci-archive:/path.tar:tag.
  --output PATH               Output EROFS image path.
  --metadata PATH             Output metadata JSON path. Defaults to OUTPUT with .ero replaced
                              by .json, or OUTPUT.json otherwise.
  --stateroot NAME            OSTree stateroot/osname. Defaults to pocketfed.
  --target-imgref IMGREF      Image reference written into the deployment origin for updates.
  --karg ARG                  Add a kernel argument to the deployment. May be repeated.
  --erofs-cluster-size BYTES  mkfs.erofs physical cluster size. Defaults to 1048576.
  --work-dir PATH             Use this empty/nonexistent work directory instead of mktemp.
  --keep-work                 Keep the temporary work directory after exit.
  -h, --help                  Show this help.

Examples:
  sudo scripts/oci-to-ostree-erofs \
    --imgref oci:base/mkosi.output/pocketfed-base.oci:rawhide \
    --output base/mkosi.output/rootfs.ostree.ero

  sudo scripts/oci-to-ostree-erofs \
    --imgref docker://registry.example/pocketfed/desktop:rawhide \
    --target-imgref registry.example/pocketfed/desktop:rawhide \
    --output build/desktop.ostree.ero
EOF
}

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

require_cmd() {
    local cmd
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || die "missing required command: $cmd"
    done
}

normalize_path_ref_payload() {
    local rest="$1"
    local path suffix

    suffix=
    path="$rest"
    if [[ "$rest" == *:* && "${rest##*:}" != */* ]]; then
        suffix=":${rest##*:}"
        path="${rest%:*}"
    fi

    [[ -n "$path" ]] || die "invalid path image reference payload: $rest"
    if [[ "$path" != /* ]]; then
        path="$(realpath "$path")"
    fi

    printf '%s%s\n' "$path" "$suffix"
}

parse_source_imgref() {
    local ref="$1"

    case "$ref" in
        oci:*)
            deploy_transport=oci
            deploy_image="$(normalize_path_ref_payload "${ref#oci:}")"
            imgref="oci:$deploy_image"
            ;;
        oci-archive:*)
            deploy_transport=oci-archive
            deploy_image="$(normalize_path_ref_payload "${ref#oci-archive:}")"
            imgref="oci-archive:$deploy_image"
            ;;
        dir:*)
            deploy_transport=dir
            deploy_image="$(normalize_path_ref_payload "${ref#dir:}")"
            imgref="dir:$deploy_image"
            ;;
        containers-storage:*)
            deploy_transport=containers-storage
            deploy_image="${ref#containers-storage:}"
            [[ -n "$deploy_image" ]] || die "invalid containers-storage image reference: $ref"
            imgref="$ref"
            ;;
        registry:*)
            deploy_transport=registry
            deploy_image="${ref#registry:}"
            [[ -n "$deploy_image" ]] || die "invalid registry image reference: $ref"
            imgref="$ref"
            ;;
        docker://*)
            deploy_transport=registry
            deploy_image="${ref#docker://}"
            [[ -n "$deploy_image" ]] || die "invalid docker image reference: $ref"
            imgref="registry:$deploy_image"
            ;;
        *)
            deploy_transport=registry
            deploy_image="$ref"
            imgref="registry:$ref"
            ;;
    esac
}

normalize_target_imgref() {
    local ref="$1"

    case "$ref" in
        oci:*)
            printf 'oci:%s\n' "$(normalize_path_ref_payload "${ref#oci:}")"
            ;;
        oci-archive:*)
            printf 'oci-archive:%s\n' "$(normalize_path_ref_payload "${ref#oci-archive:}")"
            ;;
        dir:*)
            printf 'dir:%s\n' "$(normalize_path_ref_payload "${ref#dir:}")"
            ;;
        docker://*)
            printf 'registry:%s\n' "${ref#docker://}"
            ;;
        *)
            printf '%s\n' "$ref"
            ;;
    esac
}

default_metadata_path() {
    local output="$1"

    if [[ "$output" == *.ero ]]; then
        printf '%s.json\n' "${output%.ero}"
    else
        printf '%s.json\n' "$output"
    fi
}

make_work_dir() {
    if [[ -n "$work_dir" ]]; then
        [[ ! -e "$work_dir" ]] || die "work directory already exists: $work_dir"
        mkdir -p "$work_dir"
    else
        mkdir -p "$(dirname "$output")"
        work_dir="$(mktemp -d "$(dirname "$output")/.pocketfed-ostree-erofs.XXXXXX")"
    fi
}

cleanup() {
    if [[ "$keep_work" == 1 ]]; then
        printf 'kept work directory: %s\n' "$work_dir" >&2
        return 0
    fi

    if [[ -n "$work_dir" && -d "$work_dir" ]]; then
        if command -v chattr >/dev/null 2>&1; then
            chattr -R -i "$work_dir" 2>/dev/null || true
        fi
        chmod -R u+w "$work_dir" 2>/dev/null || true
        rm -rf "$work_dir" 2>/dev/null || true
    fi
}

extract_ostree_path_from_bls() {
    local bls_entry line token
    shopt -s nullglob
    bls_entries=("$sysroot"/boot/loader/entries/*.conf)
    shopt -u nullglob

    if (( ${#bls_entries[@]} == 0 )); then
        die "no BLS entries found under $sysroot/boot/loader/entries; the image likely does not include a kernel yet"
    fi

    for bls_entry in "${bls_entries[@]}"; do
        while IFS= read -r line; do
            [[ "$line" == options* ]] || continue

            for token in ${line#options }; do
                if [[ "$token" == ostree=* ]]; then
                    printf '%s\n' "${token#ostree=}"
                    return 0
                fi
            done
        done <"$bls_entry"
    done

    die "BLS entries exist, but none contain an ostree= kernel argument"
}

validate_fastboop_layout() {
    local ostree_path="$1"
    local ostree_rel="${ostree_path#/}"
    local ostree_link="$sysroot/$ostree_rel"
    local stateroot_var="$sysroot/ostree/deploy/$stateroot/var"

    [[ -d "$sysroot/ostree" ]] || die "deployed sysroot is missing /ostree"
    [[ -L "$ostree_link" ]] || die "ostree= target is not a symlink in the sysroot: /$ostree_rel"
    [[ -d "$stateroot_var" ]] || die "deployed sysroot is missing stateroot var: /ostree/deploy/$stateroot/var"
}

relabel_sysroot() {
    local ostree_rel="${ostree_path#/}"
    local ostree_link="$sysroot/$ostree_rel"
    local deployment_root stateroot_root policy path
    local policy_candidates=()

    deployment_root="$(realpath "$ostree_link")"
    case "$deployment_root" in
        "$sysroot"/*) ;;
        *) die "resolved deployment root escapes sysroot: $deployment_root" ;;
    esac

    policy_candidates=(
        "$deployment_root/etc/selinux/targeted/contexts/files/file_contexts"
        "$deployment_root/usr/etc/selinux/targeted/contexts/files/file_contexts"
    )
    policy=
    for path in "${policy_candidates[@]}"; do
        if [[ -f "$path" ]]; then
            policy="$path"
            break
        fi
    done
    [[ -n "$policy" ]] || die "unable to find SELinux file_contexts in deployed image"

    if command -v chattr >/dev/null 2>&1; then
        chattr -R -i "$deployment_root" "$sysroot/ostree/deploy/$stateroot/var" 2>/dev/null || true
    fi

    setfiles -r "$deployment_root" -p "$policy" "$deployment_root"

    stateroot_root="$sysroot/ostree/deploy/$stateroot"
    setfiles -r "$stateroot_root" -p "$policy" "$stateroot_root/var"

    if [[ -d "$sysroot/boot" ]]; then
        setfiles -r "$sysroot" -p "$policy" "$sysroot/boot"
    fi
}

write_metadata() {
    local erofs_sha512 erofs_size kargs_json target_arg work_arg

    read -r erofs_sha512 _ < <(sha512sum "$output")
    erofs_size="$(stat -c '%s' "$output")"
    if (( ${#kargs[@]} > 0 )); then
        kargs_json="$(printf '%s\n' "${kargs[@]}" | jq -R . | jq -s .)"
    else
        kargs_json='[]'
    fi

    target_arg="$target_imgref"
    work_arg=
    if [[ "$keep_work" == 1 ]]; then
        work_arg="$work_dir"
    fi

    jq -n \
        --arg imgref "$imgref" \
        --arg requested_imgref "$requested_imgref" \
        --arg transport "$deploy_transport" \
        --arg image "$deploy_image" \
        --arg target_imgref "$target_arg" \
        --arg stateroot "$stateroot" \
        --arg commit "$commit" \
        --arg ostree_path "$ostree_path" \
        --arg ostree_cmdline "ostree=$ostree_path" \
        --arg erofs_path "$output" \
        --arg erofs_sha512 "$erofs_sha512" \
        --argjson erofs_size "$erofs_size" \
        --argjson kargs "$kargs_json" \
        --arg work_dir "$work_arg" \
        '{
          imgref: $imgref,
          requested_imgref: $requested_imgref,
          transport: $transport,
          image: $image,
          target_imgref: (if $target_imgref == "" then null else $target_imgref end),
          stateroot: $stateroot,
          commit: $commit,
          ostree_path: $ostree_path,
          ostree_cmdline: $ostree_cmdline,
          kargs: $kargs,
          erofs: {
            path: $erofs_path,
            size_bytes: $erofs_size,
            sha512: $erofs_sha512
          },
          work_dir: (if $work_dir == "" then null else $work_dir end)
        }' >"$metadata"
}

requested_imgref=
imgref=
deploy_transport=
deploy_image=
target_imgref=
output=
metadata=
stateroot="${PF_OSTREE_STATEROOT:-pocketfed}"
erofs_cluster_size="${PF_OSTREE_EROFS_CLUSTER_SIZE:-1048576}"
work_dir=
keep_work=0
kargs=()
bls_entries=()

while (( $# > 0 )); do
    case "$1" in
        --imgref)
            [[ $# -ge 2 ]] || die "--imgref requires a value"
            requested_imgref="$2"
            shift 2
            ;;
        --output)
            [[ $# -ge 2 ]] || die "--output requires a value"
            output="$2"
            shift 2
            ;;
        --metadata)
            [[ $# -ge 2 ]] || die "--metadata requires a value"
            metadata="$2"
            shift 2
            ;;
        --stateroot)
            [[ $# -ge 2 ]] || die "--stateroot requires a value"
            stateroot="$2"
            shift 2
            ;;
        --target-imgref)
            [[ $# -ge 2 ]] || die "--target-imgref requires a value"
            target_imgref="$2"
            shift 2
            ;;
        --karg)
            [[ $# -ge 2 ]] || die "--karg requires a value"
            kargs+=("$2")
            shift 2
            ;;
        --erofs-cluster-size)
            [[ $# -ge 2 ]] || die "--erofs-cluster-size requires a value"
            erofs_cluster_size="$2"
            shift 2
            ;;
        --work-dir)
            [[ $# -ge 2 ]] || die "--work-dir requires a value"
            work_dir="$2"
            shift 2
            ;;
        --keep-work)
            keep_work=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            die "unknown argument: $1"
            ;;
    esac
done

[[ -n "$requested_imgref" ]] || die "--imgref is required"
[[ -n "$output" ]] || die "--output is required"
[[ -n "$stateroot" ]] || die "--stateroot must not be empty"
[[ "$erofs_cluster_size" =~ ^[0-9]+$ ]] || die "--erofs-cluster-size must be an integer"

if (( EUID != 0 )); then
    die "run as root so OSTree deployment and EROFS metadata preserve ownership and xattrs"
fi

require_cmd grep jq mkfs.erofs ostree realpath setfiles sha512sum stat tee

parse_source_imgref "$requested_imgref"
if [[ -n "$target_imgref" ]]; then
    target_imgref="$(normalize_target_imgref "$target_imgref")"
fi
output="$(realpath -m "$output")"
if [[ -z "$metadata" ]]; then
    metadata="$(default_metadata_path "$output")"
fi
metadata="$(realpath -m "$metadata")"

make_work_dir
trap cleanup EXIT

sysroot="$work_dir/sysroot"
commit_file="$work_dir/commit.txt"
deploy_log="$work_dir/deploy.log"

mkdir -p "$sysroot" "$(dirname "$output")" "$(dirname "$metadata")"

ostree admin init-fs --modern "$sysroot"
ostree admin --sysroot="$sysroot" stateroot-init "$stateroot"
ostree --repo="$sysroot/ostree/repo" config set sysroot.bootloader none

deploy_args=(
    container image deploy
    --sysroot "$sysroot"
    --stateroot "$stateroot"
    --transport "$deploy_transport"
    --image "$deploy_image"
    --write-commitid-to "$commit_file"
)
if [[ -n "$target_imgref" ]]; then
    deploy_args+=(--target-imgref "$target_imgref")
fi
for karg in "${kargs[@]}"; do
    deploy_args+=(--karg "$karg")
done

if ! ostree "${deploy_args[@]}" 2> >(tee "$deploy_log" >&2); then
    if grep -Fq 'Failed to find kernel' "$deploy_log"; then
        die "ostree deployment failed because the image does not include a kernel yet"
    fi
    die "ostree container image deploy failed"
fi

[[ -s "$commit_file" ]] || die "ostree deploy did not write a commit id"
commit="$(<"$commit_file")"
ostree_path="$(extract_ostree_path_from_bls)"
validate_fastboop_layout "$ostree_path"
relabel_sysroot

rm -f "$output" "$metadata"
mkfs.erofs -C "$erofs_cluster_size" "$output" "$sysroot"
chmod a+r "$output"

write_metadata
chmod a+r "$metadata"

if [[ -n "${SUDO_UID:-}" && -n "${SUDO_GID:-}" ]]; then
    chown "$SUDO_UID:$SUDO_GID" "$output" "$metadata"
fi

printf '%s\n' "$output"
printf '%s\n' "$metadata"
