# OnePlus 6T (fajita) board-level devices.

# Buttons, alert slider, hall sensor, and touchscreen.
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_PM8941_PWRKEY=y
CONFIG_INPUT_FF_MEMLESS=y
CONFIG_INPUT_PM8XXX_VIBRATOR=m
CONFIG_RMI4_CORE=m
CONFIG_RMI4_I2C=m
CONFIG_RMI4_2D_SENSOR=y
CONFIG_RMI4_F12=y
CONFIG_RMI4_F55=y
CONFIG_HID_RMI=m

# Battery, fuel gauge, PMIC charger, ADCs, and USB extcon.
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_BQ27XXX=m
CONFIG_BATTERY_BQ27XXX_I2C=m
CONFIG_CHARGER_QCOM_SMB2=m
CONFIG_IIO=y
CONFIG_QCOM_VADC_COMMON=m
CONFIG_QCOM_SPMI_RRADC=m
CONFIG_QCOM_SPMI_ADC5=m
CONFIG_EXTCON=y
CONFIG_EXTCON_QCOM_SPMI_MISC=m

# Needed by the pmOS SDM845 stack for shared GPIO ownership.  This tree carries
# the symbol, but it will only be enabled if GPIO_SHARED is available too.
CONFIG_GPIO_SHARED_PROXY=m
