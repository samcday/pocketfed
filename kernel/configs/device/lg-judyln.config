# LG G7 ThinQ (judyln) board-level devices.

# Buttons, including PMIC power/resin and the ThinQ key.
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MISC=y
CONFIG_KEYBOARD_GPIO=y
CONFIG_INPUT_PM8941_PWRKEY=y

# Battery, PMI8998 charger, and ADCs.
CONFIG_POWER_SUPPLY=y
CONFIG_CHARGER_QCOM_SMB2=m
CONFIG_IIO=y
CONFIG_QCOM_VADC_COMMON=m
CONFIG_QCOM_SPMI_RRADC=m
CONFIG_QCOM_SPMI_ADC5=m

# Removable microSD.  UFS root storage remains in the SDM845 core fragment.
CONFIG_MMC=m
CONFIG_MMC_BLOCK=m
CONFIG_MMC_SDHCI=m
CONFIG_MMC_SDHCI_PLTFM=m
CONFIG_MMC_CQHCI=m
CONFIG_MMC_SDHCI_MSM=m

# Flash/status LEDs exposed by the LG device tree.
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=m
CONFIG_LEDS_CLASS_FLASH=m
CONFIG_LEDS_CLASS_MULTICOLOR=m
CONFIG_LEDS_QCOM_FLASH=m
CONFIG_PWM=y
CONFIG_LEDS_QCOM_LPG=m
