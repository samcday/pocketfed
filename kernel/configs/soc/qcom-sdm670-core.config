# Qualcomm SDM670 core platform enablement.  This shares several upstream
# drivers with SDM845, but differs in TLMM, interconnect, and root storage.

CONFIG_ARCH_QCOM=y
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_SUSPEND=y
CONFIG_HOTPLUG_CPU=y

# Firmware/resource-manager plumbing.
CONFIG_QCOM_SCM=y
CONFIG_QCOM_TZMEM=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_CLK_RPMH=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SOCINFO=y
CONFIG_HWSPINLOCK=y
CONFIG_HWSPINLOCK_QCOM=y
CONFIG_MAILBOX=y
CONFIG_QCOM_PDC=y
CONFIG_QCOM_GENI_SE=y
CONFIG_QCOM_LLCC=y

# Core clocks, pinctrl, GPIO, SPMI PMIC access, and regulators.
CONFIG_COMMON_CLK_QCOM=y
CONFIG_SDM_GCC_845=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_SDM670=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_CDEV=y
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_MFD_SPMI_PMIC=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_MSM=y
CONFIG_POWER_RESET_QCOM_PON=y
CONFIG_NVMEM=y
CONFIG_NVMEM_SYSFS=y
CONFIG_NVMEM_QCOM_QFPROM=y

# Interconnect and IOMMU fabric.
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_BCM_VOTER=y
CONFIG_INTERCONNECT_QCOM_RPMH=y
CONFIG_INTERCONNECT_QCOM_SDM670=y
CONFIG_INTERCONNECT_QCOM_OSM_L3=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_QCOM=y

# CPU idle/frequency basics.  SDM670 thermal zones are patchset-only here today.
CONFIG_CPU_IDLE=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_ARM_PSCI_CPUIDLE_DOMAIN=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_ARM_QCOM_CPUFREQ_HW=y
CONFIG_ENERGY_MODEL=y
CONFIG_SCHED_CLUSTER=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_TASK_GROUP=y
CONFIG_THERMAL=y
CONFIG_THERMAL_OF=y
CONFIG_CPU_THERMAL=y
CONFIG_QCOM_SPMI_TEMP_ALARM=m

# GENI UART/I2C/SPI buses and DMA.
CONFIG_SERIAL_QCOM_GENI=y
CONFIG_SERIAL_QCOM_GENI_CONSOLE=y
CONFIG_SERIAL_QCOM_GENI_UART_PORTS=8
CONFIG_I2C=y
CONFIG_I2C_QCOM_GENI=y
CONFIG_SPI=y
CONFIG_SPI_QCOM_GENI=m
CONFIG_DMADEVICES=y
CONFIG_QCOM_GPI_DMA=y

# eMMC root storage.  Keep this built-in so the initramfs can be loaded from it.
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_PWRSEQ_EMMC=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_CQHCI=y
CONFIG_MMC_SDHCI_MSM=y
CONFIG_BLK_INLINE_ENCRYPTION=y
CONFIG_MMC_CRYPTO=y
CONFIG_QCOM_INLINE_CRYPTO_ENGINE=y

# USB controller.  Gadget functions are modularized separately.
CONFIG_USB_SUPPORT=y
CONFIG_USB_COMMON=y
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC3=y
CONFIG_USB_DWC3_GADGET=y
CONFIG_USB_DWC3_QCOM=y
CONFIG_GENERIC_PHY=y
CONFIG_PHY_QCOM_QUSB2=y

# Qualcomm crypto/RNG blocks are small and useful for storage/network crypto.
CONFIG_CRYPTO_HW=y
CONFIG_CRYPTO_DEV_QCE=m
CONFIG_HW_RANDOM=y
CONFIG_CRYPTO_DEV_QCOM_RNG=m
