# Remote processors and Qualcomm IPC.  Frameworks are built-in where useful;
# actual SDM845 remoteproc drivers stay modular.

CONFIG_REMOTEPROC=y
CONFIG_REMOTEPROC_CDEV=y
CONFIG_RPMSG_CHAR=m
CONFIG_RPMSG_QCOM_GLINK=m
CONFIG_RPMSG_QCOM_GLINK_SMEM=m
CONFIG_RPMSG_QCOM_GLINK_RPM=m
CONFIG_RPMSG_QCOM_SMD=m

CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_LLCC=y
CONFIG_QCOM_SMP2P=m
CONFIG_QCOM_SMSM=m
CONFIG_QCOM_SYSMON=m
CONFIG_QCOM_Q6V5_ADSP=m
CONFIG_QCOM_Q6V5_MSS=m
CONFIG_QCOM_Q6V5_PAS=m
CONFIG_QCOM_RMTFS_MEM=y
CONFIG_QCOM_PD_MAPPER=m
CONFIG_QRTR=m
CONFIG_QRTR_SMD=m
CONFIG_QRTR_TUN=m

# Modem data path; modular because it is not needed to mount root.
CONFIG_QCOM_IPA=m
CONFIG_QCOM_MODEMSMEM=m
