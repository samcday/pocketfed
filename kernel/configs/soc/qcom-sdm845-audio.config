# Upstream SDM845/QDSP6 audio stack.  Voice-call helpers and some amplifier
# drivers used by pmOS are patch-only in this tree, so they are intentionally
# not listed here yet.

CONFIG_SOUND=m
CONFIG_SND=m
CONFIG_SND_PCM=m
CONFIG_SND_COMPRESS_OFFLOAD=m
CONFIG_SND_JACK=y
CONFIG_SND_SOC=m
CONFIG_SND_SOC_QCOM=m

CONFIG_QCOM_APR=m
CONFIG_SND_SOC_QDSP6=m
CONFIG_SND_SOC_SDM845=m

CONFIG_SLIMBUS=m
CONFIG_SLIM_QCOM_NGD_CTRL=m
CONFIG_MFD_WCD934X=m
CONFIG_SND_SOC_WCD934X=m

CONFIG_SND_SOC_SDCA_OPTIONAL=m
CONFIG_SOUNDWIRE=m
CONFIG_SOUNDWIRE_QCOM=m
CONFIG_SDM_LPASSCC_845=m

CONFIG_SND_SOC_TFA989X=m
