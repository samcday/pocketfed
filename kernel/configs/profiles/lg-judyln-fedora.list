# Fuller Fedora phone profile for LG G7 ThinQ.  Core platform support is built
# in; large phone features are modular.  Audio is intentionally not included
# because the live LG SDM845 device tree has no sound-card nodes yet.
arch/arm64-base.config
policy/fedora-userspace.config
policy/fedora-selinux.config
policy/fedora-storage.config
policy/fedora-networking.config
policy/containers.config
policy/zram.config
policy/usb-gadget.config
soc/qcom-sdm845-core.config
soc/qcom-sdm845-display.config
device/lg-judyln-display.config
soc/qcom-sdm845-remoteproc.config
soc/qcom-sdm845-wireless.config
device/lg-judyln.config
