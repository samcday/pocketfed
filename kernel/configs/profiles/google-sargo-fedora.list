# Fuller Fedora phone profile for Google Pixel 3a.  Core platform support is
# built in; display/GPU and the panel are modular.  Wireless, remoteproc, and
# audio nodes are not present in this source tree's live SDM670 device tree yet.
arch/arm64-base.config
policy/fedora-userspace.config
policy/fedora-selinux.config
policy/fedora-storage.config
policy/fedora-networking.config
policy/containers.config
policy/zram.config
policy/usb-gadget.config
soc/qcom-sdm670-core.config
soc/qcom-sdm670-display.config
device/google-sargo-display.config
device/google-sargo.config
