# ConfigFS USB gadget functions for recovery, debug shells, and USB networking.
# The SDM845 DWC3 controller itself is enabled by the SoC core fragment.

CONFIG_USB_GADGET=y
CONFIG_USB_LIBCOMPOSITE=m
CONFIG_USB_F_FS=m
CONFIG_USB_CONFIGFS=m
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_F_FS=y

# Avoid legacy one-shot gadgets; compose what is needed from configfs instead.
# CONFIG_USB_ETH is not set
# CONFIG_USB_MASS_STORAGE is not set
# CONFIG_USB_G_SERIAL is not set
